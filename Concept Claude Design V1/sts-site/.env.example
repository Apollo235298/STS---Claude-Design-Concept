# Copy to `.env` for local testing with `vercel dev`. Do NOT commit real values.

# Resend API key — create at https://resend.com/api-keys (secret)
RESEND_API_KEY=

# Where provider inquiries are delivered
STS_INQUIRY_TO_EMAIL=dental@stsurgery.com

# Verified Resend sender. The domain send.stsurgery.com must be verified in Resend
# (SPF/DKIM) for delivery to work.
STS_INQUIRY_FROM_EMAIL=notifications@send.stsurgery.com
